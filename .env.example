# ====================================================================
# PostgreSQL (Dashboard - NEW, isolated on port 5432)
# ====================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vibha_dashboard
POSTGRES_USER=vibha
POSTGRES_PASSWORD=vibha_dev_2024
DATABASE_URL=postgresql://vibha:vibha_dev_2024@localhost:5432/vibha_dashboard?sslmode=disable

# ====================================================================
# Kafka (SHARED with VibhaSaaS on localhost:9092)
# ====================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_QUESTIONS=rig.questions
KAFKA_TOPIC_ANSWERS=rig.answers
KAFKA_TOPIC_EVENTS=rig.events

# ====================================================================
# Ollama (SHARED with VibhaSaaS on localhost:11434)
# ====================================================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-q8_0

# ====================================================================
# Valkey (SHARED with VibhaSaaS on localhost:6379)
# ====================================================================
VALKEY_HOST=localhost
VALKEY_PORT=6379
REDIS_URL=redis://localhost:6379

# ====================================================================
# API Configuration
# ====================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# ====================================================================
# Frontend
# ====================================================================
VITE_API_URL=http://localhost:8000
VITE_ENVIRONMENT=development

# ====================================================================
# Rig Agents
# ====================================================================
RIG_LOG_LEVEL=debug
RIG_AGENT_TIMEOUT_MS=30000
